{
  "name": "@copass/olane-agents",
  "version": "0.7.5",
  "description": "Headless library for managing Olane OS host singletons + per-session agent broker daemons. Wraps @copass/datasource-olane (OS lifecycle) and @olane/o-agent (agent broker primitives) into one Copass-flavored surface that any front-end (CLI, web, MCP) can consume.",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "copass",
    "olane",
    "olane-os",
    "agents",
    "claude-code",
    "codex",
    "p2p",
    "libp2p",
    "broker"
  ],
  "author": "Olane Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olane-labs/copass.git",
    "directory": "typescript/packages/olane-agents"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@copass/datasource-olane": "^0.6.3",
    "@olane/o-agent": "^0.9.0",
    "@olane/o-config": "^0.9.0",
    "@olane/o-core": "^0.9.0",
    "@olane/o-lane": "^0.9.0",
    "@olane/o-node": "^0.9.0",
    "@olane/os": "^0.9.0",
    "e2b": "^2.19.5",
    "portfinder": "^1.0.38",
    "uuid": "^11.0.0"
  },
  "peerDependencies": {
    "@copass/core": ">=0.6.0"
  },
  "devDependencies": {
    "@copass/core": "^0.11.2",
    "@types/node": "^25.0.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.0"
  }
}
