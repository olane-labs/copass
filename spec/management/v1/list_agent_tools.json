{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "list_agent_tools",
  "description": "Return the EXACT, callable tool names available to agents in this sandbox right now \u2014 built from the user's connected integrations + always-on Copass retrieval tools (`discover` / `interpret` / `search`). **Mandatory** before writing `tool_allowlist` on `create_agent` / `update_agent_tools` \u2014 integration tools follow a prefixed shape (e.g. `pd_<app_slug>_<remote_tool_name>`); short forms like `slack_add_reaction` will not match. The enforcement layer drops any allowlist entry that doesn't match a real tool \u2014 agents with hallucinated names run tool-less. Filter by `app_slug` to narrow to one provider.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "app_slug": {
        "type": "string",
        "description": "Optional \u2014 narrow to one provider (e.g. 'slack_v2', 'gmail')."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "tools",
      "by_app",
      "count"
    ],
    "properties": {
      "tools": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "app_slug"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "app_slug": {
              "type": "string"
            },
            "description": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "by_app": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "count": {
        "type": "integer",
        "minimum": 0
      }
    },
    "additionalProperties": false
  },
  "since": "v1"
}
