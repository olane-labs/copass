{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "update_agent_tools",
  "description": "Replace an agent's `tool_allowlist` atomically. Pass the FULL desired list \u2014 partial updates aren't supported. Use `get_agent` first to fetch the current list, then supply the new full list. For wiring a freshly-OAuth'd integration into an agent, prefer `wire_integration_to_agent` \u2014 it resolves providers, unions sources, and writes the allowlist in one atomic call.",
  "inputSchema": {
    "type": "object",
    "required": [
      "slug",
      "tool_allowlist"
    ],
    "properties": {
      "slug": {
        "type": "string",
        "description": "The agent's slug."
      },
      "tool_allowlist": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Full replacement list of tool keys the agent may call."
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "required": [
          "agent"
        ],
        "properties": {
          "agent": {
            "type": "object",
            "required": [
              "agent_id",
              "slug",
              "tool_allowlist"
            ],
            "properties": {
              "agent_id": {
                "type": "string"
              },
              "slug": {
                "type": "string"
              },
              "version": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "updated_at": {
                "type": [
                  "string",
                  "null"
                ],
                "format": "date-time"
              },
              "tool_allowlist": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    ]
  },
  "since": "v1.1"
}
